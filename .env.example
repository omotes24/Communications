AI_PROVIDER=openai
NEXT_PUBLIC_APP_NAME=Yell for You 1.3
NEXT_PUBLIC_SITE_URL=
OPENAI_API_KEY=

OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_TRANSCRIPTION_DELAY=high
OPENAI_AUDIO_NOISE_REDUCTION=far_field
OPENAI_CLASSIFIER_MODEL=gpt-5.4-nano
OPENAI_ANSWER_MODEL=gpt-5.6-luna
OPENAI_RESEARCH_MODEL=gpt-5.6-terra
OPENAI_COMPANY_RESEARCH_MODEL=gpt-5.6-sol
OPENAI_INTERVIEW_LEARNING_MODEL=gpt-5.6-sol
OPENAI_QUESTION_SOLVER_MODEL=gpt-5.6-terra
OPENAI_GROUP_DISCUSSION_MODEL=gpt-5.6-terra
OPENAI_GD_MOCK_MODE=false
COMPANY_INTELLIGENCE_STRICT_MODE=true
COMPANY_INTELLIGENCE_MOCK_MODE=false
COMPANY_INTELLIGENCE_DEEP_RESEARCH_MODEL=gpt-5.6-terra
COMPANY_INTELLIGENCE_SYNTHESIS_MODEL=gpt-5.6-terra

AI_MOCK_MODE=false

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKETS=

APP_SIGNUP_GRANT_TOKENS=0
APP_REALTIME_SESSION_RESERVATION_SECONDS=180
CRON_SECRET=

# 管理ダッシュボード(/admin)にアクセスできる Supabase Auth user UUID（カンマ区切り）
ADMIN_USER_IDS=
# 既存環境からの移行用。新規登録では ADMIN_USER_IDS を使用する
ADMIN_EMAILS=
ADMIN_AUDIT_HMAC_SECRET=
OPENAI_USD_JPY_RATE=150
OPENAI_WEB_SEARCH_USD_PER_CALL=0.01
# trueで匿名Webアクセス収集を開始（公開プライバシー画面・90日保持・オプトアウト対応）
NEXT_PUBLIC_PRODUCT_ANALYTICS_ENABLED=false
# 将来機能。通常ユーザーへ公開するまでは false のままにする
INTERVIEW_EXPERIENCE_ENABLED=false

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

RESEND_API_KEY=
HELP_CONTACT_FROM_EMAIL=
HELP_CONTACT_TO_EMAIL=
